},"children":[]},{"type":"text","value":" "},{"type":"element","tag":"span","props":{"style":"font-size:0.9em"},"children":[{"type":"text","value":"นี่ผมครับ"}]},{"type":"text","value":" "}]},{"type":"text","value":"\n"},{"type":"element","tag":"h2","props":{"id":"why-this-site-"},"children":[{"type":"text","value":"Why this site ?"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"คือ ถ้าถามว่า ทำไมต้องทำเว็บนี้ละ เอาตรง ๆ คำตอบจริง ๆ ก็คือ ผมอยากมีเว็บเป็นของตัวเองบ้างครับ แต่ถ้าถามว่าทำไมถึงทำออกมาในรูปแบบนี้ คือตอนแรกผมจะทำเป็นเว็บ portfolio ของตัวเอง แต่ไหน ๆ แล้ว ก็เลยเพิ่มในส่วนของ Blog ที่เอาไว้เล่าเรื่องราวต่าง ๆ เข้ามาด้วยครับ "}]},{"type":"text","value":"\n"},{"type":"element","tag":"h2","props":{"id":"the-last-thing"},"children":[{"type":"text","value":"The last thing"}]},{"type":"text","value":"\n"},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"เริ่มนึกไม่ออกแล้ว ว่าจะเขียนอะไร คือผมเพิ่งเคยเขียนอะไรแบบนี้ครั้งแรก ก็อาจจะทำได้ไม่ดีเท่าที่ควรนะครับ แต่ผมก็อยากจะฝากเว็บไซต์และบล็อก นี้เอาไว้ในอ้อมอกอ้อมใจของทุกท่านที่เข้ามาอ่านด้วยนะครับ"}]}]},"text":"# The origin of this ต้นกำเนิดของเว็บนี้\n\nหลาย ๆ คน อาจจะยังไม่รู้จักผม หรืออาจจะรู้จักแล้วแต่ก็ยังสงสัยว่าเว็บนี้มีที่มายังไง โดยผมขอเริ่มจากการแนะนำตัวกันก่อนก็แล้วกัน\n\n## Who are me ? \n\nผม กอล์ฟ วิศรุต กิตติเจริญพรงาม (GGolfz) ณ ปัจจุบันขณะที่เริ่มเขียนบทความนี้ ผมเป็นเพียงนักศึกษาตัวเล็ก ๆ คนหนึ่ง\nที่กำลังศึกษาอยู่ในสาขาวิทยาการคอมพิวเตอร์ โดยช่วงนี้เป็นช่วงปิดเทอมครับ\nผมเลยมีเวลาค่อนข้างมาก ในการหาสิ่งใหม่ ๆ ทำ เลยทำให้เกิดขึ้นมาเป็นสิ่งนี้ครับ\n\n<p style=\"text-align:center;margin-top:2%\"><img src=\"/portfolio/profile.jpg\" alt=\"my picture\" width=\"50%\" /> <br/> <span style=\"font-size:0.9em\">นี่ผมครับ</span> </p>\n\n\n## Why this site ? \n\nคือ ถ้าถามว่า ทำไมต้องทำเว็บนี้ละ เอาตรง ๆ คำตอบจริง ๆ ก็คือ ผมอยากมีเว็บเป็นของตัวเองบ้างครับ แต่ถ้าถามว่าทำไมถึงทำออกมาในรูปแบบนี้ คือตอนแรกผมจะทำเป็นเว็บ portfolio ของตัวเอง แต่ไหน ๆ แล้ว ก็เลยเพิ่มในส่วนของ Blog ที่เอาไว้เล่าเรื่องราวต่าง ๆ เข้ามาด้วยครับ \n\n## The last thing\n\nเริ่มนึกไม่ออกแล้ว ว่าจะเขียนอะไร คือผมเพิ่งเคยเขียนอะไรแบบนี้ครั้งแรก ก็อาจจะทำได้ไม่ดีเท่าที่ควรนะครับ แต่ผมก็อยากจะฝากเว็บไซต์และบล็อก นี้เอาไว้ในอ้อมอกอ้อมใจของทุกท่านที่เข้ามาอ่านด้วยนะครับ","dir":"/blog","path":"/blog/origin","extension":".md","slug":"origin","createdAt":"2020-07-31T06:07:23.499Z","updatedAt":"2020-07-31T06:07:23.499Z","meta":{"version":0,"revision":0,"created":1596175700146},"$loki":1}],"idIndex":[1],"maxId":1,"_dirty":true,"_nestedProperties":[],"transactional":false,"asyncListeners":false,"disableMeta":false,"disableChangesApi":true,"disableDeltaChangesApi":true,"cloneObjects":false,"cloneMethod":"deep","changes":[],"_fullTextSearch":{"ii":{"title":{"_store":true,"_optimizeChanges":true,"docCount":1,"docStore":[[0,{"fieldLength":5}]],"totalFieldLength":5,"root":{"k":[116,111,3605],"v":[{"k":[104],"v":[{"k":[101,105],"v":[{"d":{"df":1,"dc":[[0,1]]}},{"k":[115],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]}]},{"k":[114,102],"v":[{"k":[105],"v":[{"k":[103],"v":[{"k":[105],"v":[{"k":[110],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]}]}]},{"d":{"df":1,"dc":[[0,1]]}}]},{"k":[3657],"v":[{"k":[3609],"v":[{"k":[3585],"v":[{"k":[3635],"v":[{"k":[3648],"v":[{"k":[3609],"v":[{"k":[3636],"v":[{"k":[3604],"v":[{"k":[3586],"v":[{"k":[3629],"v":[{"k":[3591],"v":[{"k":[3648],"v":[{"k":[3623],"v":[{"k":[3655],"v":[{"k":[3610],"v":[{"k":[3609],"v":[{"k":[3637],"v":[{"k":[3657],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}},"description":{"_store":true,"_optimizeChanges":true,"docCount":1,"docStore":[[0,{"fieldLength":5}]],"totalFieldLength":5,"root":{"k":[3627,3654,3588,3629],"v":[{"k":[3621,3619],"v":[{"k":[3634],"v":[{"k":[3618],"v":[{"d":{"df":1,"dc":[[0,1]]}}]}]},{"k":[3639],"v":[{"k":[3629],"v":[{"k":[3629],"v":[{"k":[3634],"v":[{"k":[3592],"v":[{"k":[3592],"v":[{"k":[3632],"v":[{"k":[3619],"v":[{"k":[3641],"v":[{"k":[3657],"v":[{